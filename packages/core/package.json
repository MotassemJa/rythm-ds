{
  "name": "@rythm-ds/core",
  "version": "0.0.1",
  "description": "Rythm Design System — Web Components (StencilJS)",
  "license": "MIT",
  "main": "dist/index.cjs.js",
  "module": "dist/esm/index.js",
  "es2022": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/types/index.d.ts"
    },
    "./loader": "./loader/index.js"
  },
  "files": [
    "dist",
    "loader"
  ],
  "scripts": {
    "build": "stencil build --docs",
    "dev": "stencil build --watch --serve",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "stencil test --spec",
    "test.watch": "stencil test --spec --watchAll",
    "generate": "stencil generate"
  },
  "dependencies": {
    "@rythm-ds/tokens": "^0.0.1"
  },
  "devDependencies": {
    "@stencil/angular-output-target": "^0.10.2",
    "@stencil/core": "^4.20.0",
    "@stencil/react-output-target": "^0.5.3",
    "@stencil/store": "^2.2.2",
    "@stencil/vue-output-target": "^0.8.8",
    "@types/jest": "^27.5.0",
    "jest": "^27.5.0",
    "jest-environment-jsdom": "^27.5.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@rythm-ds/tokens": "^0.0.1"
  }
}
