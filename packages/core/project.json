{
  "name": "@rythm-ds/core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "packages/core",
  "sourceRoot": "packages/core/src",
  "tags": ["scope:core", "type:lib"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist", "{projectRoot}/loader"],
      "dependsOn": ["^build"],
      "options": {
        "command": "npm run build",
        "cwd": "packages/core"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run dev",
        "cwd": "packages/core"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm test",
        "cwd": "packages/core"
      }
    }
  }
}
