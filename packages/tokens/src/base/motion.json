{
  "duration": {
    "instant": { "$value": "0ms", "$type": "duration" },
    "fast": { "$value": "100ms", "$type": "duration", "$extensions": { "rythm": { "reducedMotion": "0ms" } } },
    "normal": { "$value": "200ms", "$type": "duration", "$extensions": { "rythm": { "reducedMotion": "0ms" } } },
    "slow": { "$value": "350ms", "$type": "duration", "$extensions": { "rythm": { "reducedMotion": "0ms" } } }
  },
  "easing": {
    "standard": { "$value": "cubic-bezier(0.2, 0, 0, 1)", "$type": "cubicBezier" },
    "enter": { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "cubicBezier" },
    "exit": { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" },
    "spring": { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
  }
}
